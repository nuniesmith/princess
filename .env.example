# princess environment — copy to .env (or let `./run.sh setup-env` create it).
# .env never leaves the server; CI generates it remotely, same as freddy.

TZ=America/Toronto
SSL_DOMAIN=7gram.xyz

# Address nginx binds on. `run.sh setup-env` sets this to the host's Tailscale
# IP (tailnet-only access — the public IP serves nothing). 0.0.0.0 would make
# the edge public; Docker-published ports bypass UFW, so don't.
BIND_IP=127.0.0.1

# Tailnet IPs of the backend servers (defaults verified 2026-07-06).
# nginx's upstream maps are rewritten to these values at container start.
FREDDY_TAILSCALE_IP=100.106.65.55
SULLIVAN_TAILSCALE_IP=100.87.125.19
